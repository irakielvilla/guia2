---
import PaginaMaestrapuntoc from "./layouts/PaginaMaestrapuntoc.astro"
---
<PaginaMaestrapuntoc title="Trazoaventuras Nivel 2">
    <div id="ContenedorPrin"> 
        <div class="pizarrap">
            <img src="/portada/pizarrap.svg" alt="Pizarra">
        </div>
            
            <div class="botonp">
                 <a class="botonpa" href="/indice">
                    <img class="botonpimg" src="/portada/botonpazul.png" alt="Botón de Inicio">
                </a>
            </div>
        <div class="personaje">
           <img src="/portada/lp.png" class="lp" alt="Personaje">
        </div>
        <div class="deco">
            <img src="/portada/decop.svg">
        </div>
  </div>




<style>
    button {
background: transparent;
border: none;
padding: 0;
margin: 0;
font: inherit;
color: inherit;
cursor: pointer;
outline: none;
}
    .deco img {
        width: 150%;
        right: 12%;

        position: relative;
    }
    .deco {
        overflow: visible;
        display: flex;
        justify-content: flex-end;
        grid-column: 1/20;
        grid-row: 6/12;
        width: 120%;
        height: 100%;
        z-index: 1;

    }
    .personaje img {

        padding-top: 10%;
        height: 80%;
        padding-right: 8%;
        padding-top: 10%;
    }

    .personaje {
        position: relative;
        bottom: -4%;
        right: -12%;
        grid-column: 2/9;
        grid-row: 5/14;
        width: 100%;
        display: flex;
        z-index: 3;
        justify-content: flex-end;
    }
    .botonpa {
        position: relative;
        display: inline-block;
        width: fit-content;
    }
    .botonpimg {
        transition: transform 0.3s ease;
        width: 91%;
        position: relative;
        padding-bottom: 6%;
        right: 10%;

    }

        .botonpimg:hover{
        transform: scale(1.1);
         transition: transform 0.3s ease;
    }

    .botonp {
        margin-right: 20%;
        display: flex;
        justify-content: center;
        align-items: center;
        grid-column: 18/23;
        grid-row: 9/12;
        width: 100%;
        height: 100%;
        z-index: 10 !important;
    }
    .pizarrap {
        grid-column: 9/31;
        grid-row: 2/11;
        width: 100%;
        height: 100%;
        z-index: 3;
    }

    #ContenedorPrin {
            display: grid;
            width: 1400px;
            height: 650px;
            overflow: visible;

        

            /* Definición de Columnas: 30 módulos de 41.12px y 29 medianiles de 5.74px */
            grid-template-columns: repeat(30, 41.12px);
            column-gap: 5.74px;

            /* Definición de Filas: 14 módulos de 41.12px y 13 medianiles de 5.74px */
            grid-template-rows: repeat(14, 41.12px);
            row-gap: 5.74px;

            /* Opcional: para visualizar la retícula durante el diseño */
            /* outline: 1px solid red; 
    background-image: 
        linear-gradient(to right, rgba(0,0,0,0.1) 41.12px, transparent 5.74px),
        linear-gradient(to bottom, rgba(0,0,0,0.1) 41.12px, transparent 5.74px);
    background-size: calc(41.12px + 5.74px) calc(41.12px + 5.74px); */
        }
</style>

<script>
  // 1. Configurar el tiempo (5 minutos en milisegundos) para el navegador
  const COOLDOWN_TIME = 5 * 60 * 1000; 
  
  const lastVisit = localStorage.getItem('lastTelegramNotify');
  const now = Date.now();

  // 2. Comprobar si han pasado 5 minutos
  if (!lastVisit || (now - parseInt(lastVisit)) > COOLDOWN_TIME) {
    
    // PEGA AQUÍ LA URL LARGA QUE TE DIO GOOGLE (La que termina en /exec)
    const googleURL = 'https://script.google.com/macros/s/AKfycbwQtuJlQxU7suel_b2htXTUylIDm7k5ilf3edDmVxjh9Yd--ICiluiFhXRhfKenOw0h/exec';

    // Usamos el modo no-cors para evitar bloqueos del navegador
    fetch(googleURL, { method: 'GET', mode: 'no-cors' })
      .then(() => {
        // Guardamos la hora actual
        localStorage.setItem('lastTelegramNotify', now.toString());
        console.log("Aviso enviado a Telegram con éxito.");
      })
      .catch(err => console.error("Error al notificar:", err));

  } else {
    const minutesLeft = Math.ceil((COOLDOWN_TIME - (now - parseInt(lastVisit))) / 60000);
    console.log(`Visita reciente detectada. Faltan ${minutesLeft} min para el próximo reporte posible.`);
  }
</script>
        
</PaginaMaestrapuntoc>