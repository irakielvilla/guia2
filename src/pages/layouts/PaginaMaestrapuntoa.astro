  /* 1. Reset básico para asegurar que las medidas son exactas y no hay márgenes molestos */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
/* 2. El body: Maneja el FONDO GENERAL y el CENTRADO */
  body {
    /* --- CONFIGURACIÓN DE LA IMAGEN DE FONDO --- */
    background-image: url('/public/bg/fondoamarillo.svg'); 
    /* Asegura que la imagen cubra toda la pantalla sin repetirse y esté centrada */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    /* Evita que el fondo se mueva si hay scroll */
    background-attachment: fixed; 

    /* --- CONFIGURACIÓN DEL CENTRADO DEL CONTENEDOR --- */
    display: flex;
    justify-content: center; /* Centrado horizontal */
    align-items: flex-start;     /* Centrado vertical */
    min-height: 100vh;
    margin-top: 1%;       /* Asegura que el body ocupe todo el alto de la pantalla del navegador */
    
    /* --- COMPORTAMIENTO DE SCROLL --- */
    /* Si la ventana del navegador es más pequeña que 1400x650px, aparecerán barras de scroll */
    overflow: hidden;
  }

  

</style>