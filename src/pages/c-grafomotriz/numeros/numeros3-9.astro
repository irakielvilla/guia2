---
//import Pizarra from "./components/Pizarra.astro";
import Pizarra from "../../../components/Pizarra.astro";
// Antes tenías: "./layouts/PaginaMaestra1.astro"
import PaginaMaestra1 from "../../layouts/PaginaMaestra1.astro";
// Importamos el nuevo componente
import Barraizquierda from "../../../components/barraizquierda.astro";
// Importamos el JSON (como en tu foto)
import tablavideos from "../../../../tablavideos.json";
import PaginaMaestrapuntoa from "../../layouts/PaginaMaestrapuntoa.astro";
import Pizarragrafo from "../../../components/Pizarragrafo.astro";
import PaginaMaestrapuntoc from "../../layouts/PaginaMaestrapuntoc.astro";
import MenuDerechoNumeros from "../../../components/MenuDerechoNumeros.astro";


// Buscamos el ejercicio que coincida con esta página
const miejercicio = tablavideos.find((item) => item.id === "numeros3-9");

// Recibimos los datos como parámetros
const { video, instruccion, titulo, bdere1, bdere2, bdere3, bdere4 } =
    Astro.props;

    // Extraes el último numerito del ID ("numeros3-0" -> "0")
const numeroActual = miejercicio.id.slice(-1);

---

<PaginaMaestrapuntoc title="9 Números - Grafomotriz Inicial">
    <div id="ContenedorPrin">
        <!--inicio chorrera de codigo -->
        <Barraizquierda section="numeros" />
        <!--fin chorrera de codigo -->


        <Pizarragrafo miejercicio={miejercicio} />

        <div id="barraderecha">
            <img class="barradere" src="/barraderecha.svg" alt="" />
        </div>

        
        
        
        <MenuDerechoNumeros currentNumber={numeroActual}/>
        <div class="personaje">
            <img src="/personajes/lcp.svg" alt="">  
        </div>

        <div class="botonp">
                 <a class="botonpa" href="/indice/contraportada">
                    <img class="botonpimg" src="/portada/botonpamarillo.png" alt="Botón de Inicio">
                </a>
            </div>
        <!-- <div id="bbarraderecha">
            <a href="/c-grafomotriz/numeros/numeros3-0/"><img class="ejers" src={miejercicio.bdere1} alt="" />
                    </a>

            <a href="/c-grafomotriz/numeros/numeros3-1/"
                ><img class="ejers" src={miejercicio.bdere2} alt="" />
            </a>

            <a href="/c-grafomotriz/numeros/numeros3-2/"
                ><img class="ejers" src={miejercicio.bdere3} alt="" />
            </a>

            <a href="/c-grafomotriz/numeros/numeros3-3/"
                ><img class="ejers" src={miejercicio.bdere4} alt="" />
            </a>

            <a href="/c-grafomotriz/numeros/numeros3-4/"
                ><img class="ejers" src={miejercicio.bdere5} alt="" />
            </a>
        </div> -->
    </div>

    <style>
        :global(.botonpimg:hover){
        transform: scale(1.2);
        transition: transform 0.3s ease;
    }
        
        .botonpa {
        position: relative;
        display: inline-block;
        width: fit-content;
    }
    .botonpimg {
        width: 80%;
        position: relative;
        left: 12%;
        transition: transform 0.3s ease;


    }
    .botonp {
        padding-top: 15%;
        padding-bottom: 80%;
        display: flex;
        justify-content: center;
        align-items: center;
        grid-column: 27/29 !important;
        grid-row: 1/4 !important;
        width: 100%;
        height: 100%;
        z-index: 10 !important;
    }
        .personaje {
            grid-column: 23/26;
            grid-row: 1/6;
            width: 85%;
            z-index: 5;
            display: flex;
            justify-content: center;
            align-items: flex-end;
            padding-bottom: 32%;
            padding-left: 56%;
        }
        .personaje img {
            object-fit: contain;
            height: 80%;
        }
        #ContenedorPrin {
            display: grid;
            width: 1400px;
            height: 650px;
            overflow: visible;

            /* Definición de Columnas: 30 módulos de 41.12px y 29 medianiles de 5.74px */
            grid-template-columns: repeat(30, 41.12px);
            column-gap: 5.74px;

            /* Definición de Filas: 14 módulos de 41.12px y 13 medianiles de 5.74px */
            grid-template-rows: repeat(14, 41.12px);
            row-gap: 5.74px;

            /* Opcional: para visualizar la retícula durante el diseño */
            /* outline: 1px solid red; 
    background-image: 
        linear-gradient(to right, rgba(0,0,0,0.1) 41.12px, transparent 5.74px),
        linear-gradient(to bottom, rgba(0,0,0,0.1) 41.12px, transparent 5.74px);
    background-size: calc(41.12px + 5.74px) calc(41.12px + 5.74px); */
        }

        #Pizarra {
            grid-column: 7/27;
            grid-row: 4/14;
            z-index: 1;
            display: flex; /* Activa el modo flexible */
            justify-content: center; /* Centra horizontalmente (Eje X) */
            align-items: center; /* Centra verticalmente (Eje Y) */
        }
        .pizarraimg {
            object-fit: contain;
        }

        

        #bbarraderecha {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            grid-column: 27/30;
            grid-row: 6/15;
            object-fit: none;
            margin-left: 27%;
            margin-right: 27%;
        }

        .ejers {
            width: 100%;
            height: 62%;
            transition: transform 0.3s ease; /* Agrega una transición suave para el efecto de zoom */
            
        }

        .ejers:hover {
            transform: scale(1.25);
        }
        #barraderecha {
            grid-column: 26/31;
            grid-row: 3/15;
            object-fit: none;
            padding-top: 12%;
            margin-left: 15%;
        }
        .barradere {
        }

        .opciones2 {
            padding-right: 5px; /*ARREGLAR ESTOOOO*/
            height: 100%;
            padding-top: 14px;
        }

        #barraizquier {
            grid-column: 1/21;
            grid-row: 1/14;
        }

        .barraiz {
            width: 100%;
            height: 100%;
        }

        .pregracc:hover {
            color: blue;
        }
    </style>
</PaginaMaestrapuntoc>
