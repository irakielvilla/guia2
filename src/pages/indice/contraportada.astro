---
import PaginaMaestrapuntoc from "../layouts/PaginaMaestrapuntoc.astro";


---
<PaginaMaestrapuntoc title="Contraportada">
    <div id="ContenedorPrin"> 

        <div class="personajes">
            <a class="nivel2" href="https://trazoaventuras1.vercel.app">
                <img class="nivel12img" src="/portada/nivel2.svg" alt="Nivel 2">
            </a>
            <a class="nivel3" href="https://trazoaventuras3.vercel.app">
                <img class="nivel13img" src="/portada/nivel3.svg" alt="Nivel 3">
            </a>
        </div>
        <div class="pizarrafinal">
            <img src="/portada/pizarracp.svg" alt="Pizarra Final">
        </div>

        <div class="creditos">
            <img src="/portada/creditos.svg" alt="creditos">
        </div>

        <div class="botonp">
                 <a class="botonpa" href="/c-grafomotriz/numeros2/numeros2-29/">
                    <img class="botonpimg" src="/portada/botonpamarillo.png" alt="Botón de Inicio">
                </a>
            </div>
        
    
  </div>

<style>
    .nivel3 {
        padding-top: 1%;
        width: 50%;
    }
    .nivel13img {
        transition: transform 0.3s ease;
         }

    :global(.nivel13img:hover){
        transform: scale(1.05);
        transition: transform 0.3s ease;

    }


    .nivel2 {
        width: 43%;
        position: relative;
        top: -20%;
        right: -4%;
        
    }
    .nivel12img {
        transition: transform 0.3s ease;
         }
        
    
    :global(.nivel12img:hover){
        transform: scale(1.05);
        transition: transform 0.3s ease;

    }

    :global(.botonpa) {
        position: relative;
        display: inline-block;
        width: fit-content;
        ;
    }
    .botonpimg {
        width: 75%;
        position: relative;
        rotate: 180deg;
        left: 12%;
        transition: transform 0.3s ease;
    }
    :global(.botonpimg:hover){
        transform: scale(1.2);
        transition: transform 0.3s ease;
    }
    .botonp {

        display: flex;
        justify-content: center;
        align-items: center;
        grid-column: 28/30 !important;
        grid-row: 2/4 !important;
        width: 100%;
        height: 100%;
        z-index: 10 !important;
        trasition: transform 0.3s ease;
    }
    :global(.personajes img) {
        height: 80%;
        width: auto;
        position: relative;
    }
    :global(.personajes) {
        
        grid-column: 14 /  21; 
        grid-row: 9 /  14;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        z-index: 5;
        padding-right: 6.5%;
    }
    .creditos img {
        height: 100%;
        position: relative;
        left: 2%;

    }
    .creditos {
        grid-column: 22 /  31; 
        grid-row: 2 /  14;
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
    }
    .pizarrafinal img {
       height: 105.6%;
       padding-bottom: 3.2%;
       position: relative;
         left: -2.5%;
    }
    .pizarrafinal {
        display: flex;
        grid-column: 2 /  22; /* Ocupa las 30 columnas */
        grid-row: 1 /  15;    /* Ocupa las 14 filas */
        width: 100%;
        height: 100%;
        justify-content: flex-start;
        align-items: center;
    }
       
    body {

    background-color: #d1d1d1;
    margin: 0;
    padding: 0;
    /* --- CONFIGURACIÓN DE LA IMAGEN DE FONDO --- */
    background-image: url('/bg/fondorojo.svg'); 
    /* Asegura que la imagen cubra toda la pantalla sin repetirse y esté centrada */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    /* Evita que el fondo se mueva si hay scroll */

    /* --- CONFIGURACIÓN DEL CENTRADO DEL CONTENEDOR --- */
    display: flex;
    justify-content: center; /* Centrado horizontal */
    align-items: center;     /* Centrado vertical */
    height: 100dvh; /* Usamos alto dinámico */
    width: 100vw;
    overflow: hidden;
    }

    #ContenedorPrin {
            display: grid;
            width: 1400px;
            height: 650px;
            overflow: visible;

        

            /* Definición de Columnas: 30 módulos de 41.12px y 29 medianiles de 5.74px */
            grid-template-columns: repeat(30, 41.12px);
            column-gap: 5.74px;

            /* Definición de Filas: 14 módulos de 41.12px y 13 medianiles de 5.74px */
            grid-template-rows: repeat(14, 41.12px);
            row-gap: 5.74px;

            /* Opcional: para visualizar la retícula durante el diseño */
            /* outline: 1px solid red; 
    background-image: s
        linear-gradient(to right, rgba(0,0,0,0.1) 41.12px, transparent 5.74px),
        linear-gradient(to bottom, rgba(0,0,0,0.1) 41.12px, transparent 5.74px);
    background-size: calc(41.12px + 5.74px) calc(41.12px + 5.74px); */
        }
</style>
        </PaginaMaestrapuntoc>