---
// Componente: Pizarratutorial1.astro
const { miejercicio } = Astro.props;

if (!miejercicio) {
  return Astro.redirect("/");
}

// 🗺️ MAPA DE NAVEGACIÓN VERTICAL CORREGIDO CON TUS RUTAS EXACTAS
const secuenciaPasos = ["puntoa-a", "paso1", "paso2", "paso3", "paso4"];
const posicionActual = secuenciaPasos.indexOf(miejercicio.id);

// Calculamos los IDs hermanos de forma segura para no desbordar el array
const idAnterior = posicionActual > 0 ? secuenciaPasos[posicionActual - 1] : undefined; // Desactiva si es el primer paso
const idSiguiente = posicionActual < secuenciaPasos.length - 1 ? secuenciaPasos[posicionActual + 1] : secuenciaPasos[secuenciaPasos.length - 1];

// 🚀 RUTAS OFICIALES CONECTADAS DE FORMA EXACTA
const arribaUrl = idAnterior ? `/a-partida/puntoa/${idAnterior}` : undefined; // URL solo si no es el primer paso
const abajoUrl = `/a-partida/puntoa/${idSiguiente}`;

// 🧠 FILTRO DINÁMICO DE PÁGINAS DEL CARRUSEL (Texto + Imagen)
const pagKeys = Object.keys(miejercicio).filter(key => key.startsWith('pag'))
  .sort((a, b) => {
    const numA = parseInt(a.replace('pag', ''), 10);
    const numB = parseInt(b.replace('pag', ''), 10);
    return numA - numB;
  });

const paginas = pagKeys.map(key => {
  return {
    src: miejercicio[key], // Asumimos que pagX ahora contiene la ruta de la imagen
  };
});
---

<div id="pizarrabase">
  <img class="esquinas" src="/esquinasamarillas.png" alt="Esquinas" />
</div>

<div id="Pestanatitulo">
  <img src={miejercicio.titulo} alt="Título" />
</div>

<div id="pizarracomp">
  <div class="pizarraprincipal"></div>
  <div id="bordeazul"></div>
</div>

<div id="fondoazulinfo"></div>
{paginas.length > 0 && (
      <img id="img-tutorial-dinamica" src={paginas[0].src} alt="Tutorial" />
    )}


<div id="contenedor-swiper-texto">
  <div class="swiper mySwiperTutorial">
    <div class="swiper-wrapper">
      {paginas.map((pag, index) => (
        <div class="swiper-slide" data-slide-image={pag.src}>
          <img src={pag.src} alt={`Instrucción ${index + 1}`} class="img-tutorial-carrusel" />
        </div>
      ))}
    </div>
    
    <div class="swiper-pagination"></div>
  </div>
</div>

<div id="navegadorpasos">
  <a id="arriba" class:list={['navegador-btn', posicionActual === 0 && 'is-disabled']} href={arribaUrl} title="Ir al paso anterior">
    <img class="arribab" src="/puntoa/arriba2.svg" alt="Arriba">
    <img class="fondob" src="/puntoa/fondoarriba2.svg" alt="Fondo">
  </a>
  <a id="abajo" class="navegador-btn" href={abajoUrl} title="Ir al paso siguiente">
    <img class="abajob" src="/puntoa/abajo2.svg" alt="Abajo">
    <img class="fondobajo" src="/puntoa/fondoabajo2.svg" alt="Fondo">
  </a>
</div>

<style is:global>
  #img-tutorial-dinamica{
    visibility: hidden;
  }
  /* Cápsula Desactivada (Estado por defecto) */
  .mySwiperTutorial .swiper-pagination-bullet {
    background-color: transparent !important; /* Eliminamos el círculo gris nativo */
    background-image: url('/puntoa/capsuladesac.svg') !important; /* Tu SVG inactivo */
    background-size: contain !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    opacity: 1 !important; /* Forzamos opacidad completa para ver los colores reales del SVG */
    border-radius: 0px !important; /* Remueve el redondeado CSS ya que el SVG define la forma */
    
    /* 🛠️ Modifica estos dos valores según la proporción de tu SVG desactivado */
    width: 14.5% !important;
    height: 12.25px !important;  
    
    transition: all 0.3s ease !important;
    margin: 0 1.8% !important;
    z-index: 10 !important;
  }

  /* Efecto Hover para las cápsulas */
  .mySwiperTutorial .swiper-pagination-bullet:hover {
    transform: scale(1.1) !important;
  }
  

  /* Cápsula Activada (Slide donde está interactuando el niño) */
  .mySwiperTutorial .swiper-pagination-bullet-active {
    background-image: url('/puntoa/capsulaact.png') !important; /* Tu SVG activo alargado */
    
    /* 🛠️ Ajusta el ancho para que coincida con el estiramiento de tu diseño en Illustrator */
    width: 14.5% !important;
  }
</style>

<style>
  #pizarrabase {
    border-radius: 50px;
    grid-column: 6/27;
    grid-row: 4/15;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 40px;
  }

  .esquinas {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  #Pestanatitulo {
    margin-left: 8.8%;
    margin-right: 8.8%;
    grid-column: 17/27;
    grid-row: 4/6;
    max-width: 100%;
    z-index: 1;
  }

  #pizarracomp {
    background-color: #F4DB74;
    grid-column: 7/26;
    grid-row: 5/14;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    margin: 2.38%;
    border-radius: 20px;
  }

  .pizarraprincipal {
    width: 100%;
    height: 100%;
    background-color: #0668A9;
    border-radius: 20px;
    box-sizing: border-box;
  }

  #fondoazulinfo {
    background-color: #ffffff;
    grid-row: 5/14;
    grid-column: 7/23;
    z-index: 4;
    margin: 5.5% 0px 5.5% 5.5%;
    border-radius: 20px;
  }

  #contenedor-swiper-texto {
    grid-row: 6/13;
    grid-column: 11/23;
    z-index: 5;
    box-sizing: border-box;
    margin-top: 9.2%;
    margin-right: 8%;
    margin-left: 1%;


  }

  .swiper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .swiper-slide {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    box-sizing: border-box;
  }

  .fredoka-texto {
    font-family: "Fredoka", sans-serif;
    font-size: 125%;
    color: #666666;
    text-align: left;
    line-height: 1.2;
    margin: 0;
    font-weight: 300;
  }

  .swiper-pagination {
    top: 78% !important;
    bottom: 17% !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    z-index: 10 !important;
    display: flex;
    justify-content: flex-start;
  }

  #navegadorpasos {
    justify-content: space-between;
    display: flex;
    align-items: center;
    flex-direction: column;
    grid-column: 22/24;
    grid-row: 7/12;
    width: 100%;
    z-index: 5;
    margin-top: 80%;
    margin-bottom: 80%;
    row-gap: 96%;
  }

  .navegador-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 66%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .fondob {
    position: absolute;
  }
  .arribab {
    position: absolute;
    z-index: 6;
    width: 77%;
    transition: calc(0.2s);
    opacity: 0.3;
  }

  .arribab:hover {
    transform: scale(1.1);
  }

  .fondobajo {
    position: absolute;
    width: 84%;
  }
  .abajob {
    position: absolute;
    z-index: 6;
    width: 60%;
   transition: transform 0.2s ease;
  }
 .abajob:hover {
    transform: scale(1.1);
  }



</style>

<script>
  import Swiper from "swiper";
  import { Pagination } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  const habilitarPizarraInteractiva = () => {
    const imgDinamica = document.getElementById("img-tutorial-dinamica") as HTMLImageElement;

    if (!imgDinamica) return;

    new Swiper(".mySwiperTutorial", {
      modules: [Pagination],
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      on: {
        init: function () {
          const slideInicial = this.slides[this.activeIndex];
          if (slideInicial) {
            const rutaImg = slideInicial.getAttribute("data-slide-image"); // Usará pag.src
            if (rutaImg) imgDinamica.src = rutaImg;
          }
        },
        slideChange: function () {
          const slideActivo = this.slides[this.activeIndex];
          
          if (slideActivo) {
            const nuevaRuta = slideActivo.getAttribute("data-slide-image"); // Usará pag.src
            
            if (nuevaRuta) {
              imgDinamica.style.opacity = "0.1";
              
              setTimeout(() => {
                imgDinamica.src = nuevaRuta;
                imgDinamica.style.opacity = "1";
              }, 150);
            }
          }
        },
      },
    });
  };

  document.addEventListener("DOMContentLoaded", habilitarPizarraInteractiva);
  document.addEventListener("astro:page-load", habilitarPizarraInteractiva);
</script>