---
// Componente: Pizarratutorial1.astro
const { miejercicio } = Astro.props;

if (!miejercicio) {
  return Astro.redirect("/");
}

// 🗺️ MAPA DE NAVEGACIÓN VERTICAL CORREGIDO CON TUS RUTAS EXACTAS
const secuenciaPasos = ["puntoa-a", "paso1", "paso2", "paso3", "paso4"];
const posicionActual = secuenciaPasos.indexOf(miejercicio.id);

// Calculamos los IDs hermanos de forma segura para no desbordar el array
const idAnterior = posicionActual > 0 ? secuenciaPasos[posicionActual - 1] : secuenciaPasos[0];
const idSiguiente = posicionActual < secuenciaPasos.length - 1 ? secuenciaPasos[posicionActual + 1] : undefined;

// 🚀 RUTAS OFICIALES CONECTADAS DE FORMA EXACTA
const arribaUrl = `/a-partida/puntoa/${idAnterior}`;
const abajoUrl = idSiguiente ? `/a-partida/puntoa/${idSiguiente}` : undefined;

// 🧠 FILTRO DINÁMICO DE PÁGINAS DEL CARRUSEL (Texto + Imagen)
const pagKeys = Object.keys(miejercicio)
  .filter(key => key.startsWith('pag'))
  .sort((a, b) => {
    const numA = parseInt(a.replace('pag', ''), 10);
    const numB = parseInt(b.replace('pag', ''), 10);
    return numA - numB;
  });

const paginas = pagKeys.map(key => {
  const num = key.replace('pag', '');
  return {
    num: num, // 🌟 NUEVO: Guardamos el número de página limpio (ej: "11", "12")
    texto1: miejercicio[key],
    imagen: miejercicio[`imgpag${num}`] || `/puntoa/${miejercicio.id}img${num}.svg`
  };
});
---

<div id="pizarrabase">
  <img class="esquinas" src="/esquinasamarillas.png" alt="Esquinas" />
</div>

<div id="Pestanatitulo">
  <img src={miejercicio.titulo} alt="Título" />
</div>

<div id="pizarracomp">
  <div class="pizarraprincipal"></div>
  <div id="bordeazul"></div>
</div>

<div id="fondoazulinfo"></div>

<div id="contenedor-info">
  {paginas[0] && (
    <img id="img-tutorial-dinamica" src={paginas[0].imagen} alt="Material Inicial" />
  )}
</div>

<div id="contenedor-swiper-texto">
  <div class="swiper mySwiperTutorial">
    <div class="swiper-wrapper">
      {paginas.map((pag, index) => (
        <div class="swiper-slide" data-slide-image={pag.imagen}>
          <img src={pag.texto1}>
        </div>
      ))}
    </div>
    
    <div class="swiper-pagination"></div>
  </div>
</div>

<div id="navegadorpasos">
  <a id="arriba" class="navegador-btn" href={arribaUrl} title="Ir al paso anterior">
    <img class="arribab" src="/puntoa/arriba.svg" alt="Arriba">
    <img class="fondob" src="/puntoa/fondoarriba.svg" alt="Fondo">
  </a>
  <a id="abajo" class:list={['navegador-btn', !idSiguiente && 'is-disabled']} href={abajoUrl} title="Ir al paso siguiente">
    <img class="abajob" src="/puntoa/abajo.svg" alt="Abajo">
    <img class="fondobajo" src="/puntoa/fondoabajo.svg" alt="Fondo">
  </a>
</div>

<style is:global>
  /* Cápsula Desactivada (Estado por defecto) */
  .mySwiperTutorial .swiper-pagination-bullet {
    background-color: transparent !important; /* Eliminamos el círculo gris nativo */
    background-image: url('/puntoa/capsuladesac.svg') !important; /* Tu SVG inactivo */
    background-size: contain !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    opacity: 1 !important; /* Forzamos opacidad completa para ver los colores reales del SVG */
    border-radius: 0px !important; /* Remueve el redondeado CSS ya que el SVG define la forma */
    
    /* 🛠️ Modifica estos dos valores según la proporción de tu SVG desactivado */
    width: 14.5% !important;
    height: 12.25px !important;  
    
    transition: all 0.3s ease !important;
    margin: 0 3.7% !important;
  }

  /* Efecto Hover para las cápsulas */
  .mySwiperTutorial .swiper-pagination-bullet:hover {
    transform: scale(1.1) !important;
  }

  /* Cápsula Activada (Slide donde está interactuando el niño) */
  .mySwiperTutorial .swiper-pagination-bullet-active {
    background-image: url('/puntoa/capsulaact.png') !important; /* Tu SVG activo alargado */
    
    /* 🛠️ Ajusta el ancho para que coincida con el estiramiento de tu diseño en Illustrator */
    width: 14.5% !important;
  }
</style>

<style>
  #pizarrabase {
    border-radius: 50px;
    grid-column: 6/27;
    grid-row: 4/15;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 40px;
  }

  .esquinas {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  #Pestanatitulo {
    margin-left: 8.8%;
    margin-right: 8.8%;
    grid-column: 17/27;
    grid-row: 4/6;
    max-width: 100%;
    z-index: 1;
  }

  #pizarracomp {
    background-color: #FFB072;
    grid-column: 7/26;
    grid-row: 5/14;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    margin: 2.38%;
    border-radius: 20px;
  }

  .pizarraprincipal {
    width: 100%;
    height: 100%;
    background-color: #FFD2B0;
    border-radius: 20px;
    box-sizing: border-box;
  }

  #fondoazulinfo {
    background-color: #145B10;
    grid-row: 5/14;
    grid-column: 7/23;
    z-index: 4;
    margin: 5.5% 0px 5.5% 5.5%;
    border-radius: 20px;
  }

  #contenedor-info {
    grid-row: 6/13;
    grid-column: 7/13;
    background-color: #ff9139;
    z-index: 5;
    border-radius: 0px 54px 54px 0px;
    margin: 15% 13% 15% 14.8%;  /*cambiar el 14.8 en todos*/
    border-top: 5.9px solid #ae6508;
    border-right: 5.9px solid #ae6508;
    border-bottom: 5.9px solid #ae6508;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    /* 🌟 NUEVO: CSS para el Fade In / Fade Out automático */
    transition: opacity 0.4s ease-in-out;
    opacity: 1;
  }

  #img-tutorial-dinamica {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
    transition: opacity 0.2s ease-in-out; 
  }

  #contenedor-swiper-texto {
    grid-row: 6/13;
    grid-column: 13/22;
    z-index: 5;
    box-sizing: border-box;
    margin-top: 10%;
  }

  .swiper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .swiper-slide {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    box-sizing: border-box;
  }

  .fredoka-texto {
    font-family: "Fredoka", sans-serif;
    font-size: 125%;
    color: #ffffff;
    text-align: left;
    line-height: 1.2;
    margin: 0;
    font-weight: 300;
  }

  .swiper-pagination {
    bottom: 16% !important;
    left: 50% !important;
    transform: translateX(-49%) !important;
    z-index: 10;
    display: flex;
    justify-content: flex-start;
  }

  #navegadorpasos {
    justify-content: space-between;
    display: flex;
    align-items: center;
    flex-direction: column;
    grid-column: 22/24;
    grid-row: 7/12;
    width: 100%;
    z-index: 5;
    margin-top: 80%;
    margin-bottom: 80%;
    row-gap: 96%;
  }

  .navegador-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 66%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .fondob {
    position: absolute;
  }
  .arribab {
    position: absolute;
    z-index: 6;
    width: 77%;
    transition: transform 0.2s ease;

  }

  .arribab:hover {
    transform: scale(1.1);
  }

  .fondobajo {
    position: absolute;
    width: 84%;
  }
  .abajob {
    position: absolute;
    z-index: 6;
    width: 60%;
    transition: transform 0.2s ease;
  }
  .abajob:hover {
    transform: scale(1.1);
  }


  .is-disabled {
    pointer-events: none;
    cursor: default;
  }

  .is-disabled .abajob {
    opacity: 0.3;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Pagination } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  const habilitarPizarraInteractiva = () => {
    console.log("🚀 Iniciando script de la Pizarra Interactiva...");

    const imgDinamica = document.getElementById("img-tutorial-dinamica") as HTMLImageElement;
    const contenedorInfo = document.getElementById("contenedor-info");

    console.log("🖼️ ¿Encontró la imagen dinámica?:", !!imgDinamica);
    console.log("📦 ¿Encontró el contenedor amarillo?:", !!contenedorInfo);

    if (!imgDinamica) {
        console.warn("⚠️ Abortando: No se encontró la imagen dinámica.");
        return;
    }

    const verificarFadeContenedor = (slideActual) => {
      if (!contenedorInfo || !slideActual) return;
      
      const numPagina = slideActual.getAttribute("data-slide-num");
      console.log("📄 Evaluando número de página en este slide:", numPagina);
      
      // Condicional de Fade
      if (numPagina === "12" || numPagina === "13") {
        console.log("👻 ¡BINGO! Es 12 o 13. Aplicando Fade-Out (ocultando)...");
        contenedorInfo.style.opacity = "0";
        contenedorInfo.style.pointerEvents = "none";
      } else {
        console.log("👀 Página normal. Aplicando Fade-In (mostrando)...");
        contenedorInfo.style.opacity = "1";
        contenedorInfo.style.pointerEvents = "auto";
      }
    };

    new Swiper(".mySwiperTutorial", {
      modules: [Pagination],
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      on: {
        init: function () {
          console.log("⚙️ Swiper inicializado correctamente.");
          const slideInicial = this.slides[this.activeIndex];
          if (slideInicial) {
            const rutaImg = slideInicial.getAttribute("data-slide-image");
            if (rutaImg) imgDinamica.src = rutaImg;
            
            verificarFadeContenedor(slideInicial);
          }
        },
        slideChange: function () {
          console.log("➡️ Cambio de slide detectado.");
          const slideActivo = this.slides[this.activeIndex];
          
          if (slideActivo) {
            verificarFadeContenedor(slideActivo);

            const nuevaRuta = slideActivo.getAttribute("data-slide-image");
            
            if (nuevaRuta) {
              imgDinamica.style.opacity = "0.1";
              
              setTimeout(() => {
                imgDinamica.src = nuevaRuta;
                imgDinamica.style.opacity = "1";
              }, 150);
            }
          }
        },
      },
    });
  };

  document.addEventListener("DOMContentLoaded", habilitarPizarraInteractiva);
  document.addEventListener("astro:page-load", habilitarPizarraInteractiva);
</script>