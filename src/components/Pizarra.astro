---
// import Swiper JS
import Swiper from "swiper";
// import Swiper styles
import "swiper/css";
// Recibimos los datos como parámetros
// const { videos } = Astro.props;
// Recibimos los datos
const { miejercicio } = Astro.props;

// ESTO ES PARA DEPURAR: Verás el resultado en la terminal de VS Code
console.log("Datos recibidos en Pizarra:", miejercicio);
// ESTA ES LA CLAVE: Si miejercicio no existe, creamos uno vacío
// para que el build no se rompa
if (!miejercicio) {
  return Astro.redirect("/");
  // O simplemente: const miejercicio = { video: '', titulo: '', instruccion: '' };
}
---

<div id="pizarrabase">
  <img class="esquinas" src="/esquinas.png" alt="" />
</div>

<div id="Pestanatitulo">
  <img src={miejercicio.titulo} alt="" />
</div>

<div id="repro">
  <button id="btn-play-pausa" class="botonrepro"
    ><img class="reprod" src="/botonplay.svg" alt="Play/Pausa" />
  </button>
  <button id="btn-replay" class="botonrepro"
    ><img class="reprod" src="/botonreplay.svg" alt="Replay" />
  </button>
</div>

<div id="pizarracomp">
  <div class="pizarraprincipal">
    <video
      id="video-p"
      src={miejercicio.video}
      autoplay
      muted
      playsinline
    >
    </video>
    <div id="bordeazul"></div>
  </div>
</div>
<div id="contenedor-info">
  <p set:html={miejercicio.instruccion}></p>
</div>

<style>
  .pizarraprincipal {
    display: flex;
    background-color: #ffffff;
    border-radius: 20px;
    /* border: 20px solid #188AE3; */
    box-sizing: border-box;
    overflow: hidden;
    position: relative;
    width: 100%;
    height: 100%;
    justify-content: center;
    align-items: center;
  }

  #pizarracomp {
    background-color: #94dd8e;
    grid-column: 7/26;
    grid-row: 5/14;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    margin: 2.38%;
    border-radius: 20px;
  }

  video {
    overflow: hidden;
    height: 101%;
    width: 101%;
    /* LA CLAVE: Evita que Flexbox lo aplaste hacia adentro */
  flex-shrink: 0; 
  
  /* Mantiene la proporción sin deformar la imagen y recorta el exceso (ideal si el video trae bandas negras de origen) */
  object-fit: cover;
  }

  #contenedor-info {
    grid-row: 6/13;
    grid-column: 7/13;
    background-color: #2DA323;
    z-index: 5;
    padding-top: 40px;
    border-radius: 0px 54px 54px 0px;
    margin: 15% 13% 15% 15%;
    border-top: 5.9px solid #23841A;
    border-right: 5.9px solid #23841A;
    border-bottom: 5.9px solid #23841A;
  }
  #contenedor-info p {
    font-family: "Fredoka", sans-serif;
    font-weight: 300;
    color: #ffffff;
    text-align: center;
    padding-left: 12%;
    padding-right: 10.4%;
    font-size: 95%;
    letter-spacing: -0.1%;
    line-height: 130%;
    text-align: left;
  }

  #pizarrabase {
    border-radius: 50px;
    grid-column: 6/27;
    grid-row: 4/15;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 40px;
  }

  .esquinas {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }


  #repro {
    margin-top: 48%;
    margin-bottom: 40%;
    grid-row: 7/12;
    grid-column: 25/27;
    display: flex;
    z-index: 1;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    row-gap: 2.5%;
  }

  #repro button {
    background: none;
    border: none;
    padding: 0px;
    cursor: pointer;
  }

  .reprod {
    width: 100%;
  }

  .reprod:hover {
    transform: scale(1.25);
  }

  #decorepro {
    width: 65%;
    margin-bottom: 4%;
  }

  .reprodd {
    width: 100%;
        }

        #Pestanatitulo {
            margin-left:8.8%;
            margin-right: 8.8%;
            grid-column: 17/27;
            grid-row: 4/6;
            max-width: 100%;
            z-index: 1;
        }

  
</style>

<script>
  const inicializarVideo = () => {
    const video =
      (document.getElementById("video-p") as HTMLVideoElement) ||
      document.querySelector("video");
    const btnPlay = document.getElementById("btn-play-pausa");
    const btnReplay = document.getElementById("btn-replay");

    console.log("--- Reporte de Conexión ---");
    console.log("Video encontrado:", !!video);
    console.log("Botón Play encontrado:", !!btnPlay);
    console.log("Botón Replay encontrado:", !!btnReplay);

    if (video && btnPlay && btnReplay) {
      btnPlay.onclick = () => {
        if (video.paused) {
          video.play();
          console.log("▶️ Reproduciendo...");
        } else {
          video.pause();
          console.log("⏸️ Pausado.");
        }
      };

      btnReplay.onclick = () => {
        video.currentTime = 0;
        video.play();
        console.log("🔄 Replay activado.");
      };

      console.log("✅ ¡Todo listo! Los botones ya controlan el video.");
    } else {
      console.error(
        "❌ Error: No se pudo establecer la conexión. Revisa que los IDs coincidan."
      );
    }
  };

  // Ejecución inmediata al cargar el componente
  inicializarVideo();

  // Refuerzo: Astro a veces necesita un pequeño respiro para juntar los componentes
  setTimeout(inicializarVideo, 500);
</script>
