<style>
  #grupo-numeros-4 .btn-numero img {
    width: 101% !important; 
  }
   #grupo-numeros-1{
    position: relative;
    top: -4.5% !important;
    gap: 10% !important;
  }
  #grupo-numeros-2{
    position: relative;
    top: -4.5% !important;
    gap: 10% !important;
  }
  #grupo-numeros-3{
    position: relative;
    top: -4.5% !important;
    gap: 11% !important;
  }
  #grupo-numeros-4{
    position: relative;
    top: -4.5% !important;
    gap: 11% !important;
  }
  #btn-arriba{
    margin-bottom: -30%;
    width: 60%;
  }
  #btn-abajo{
    width: 60%;
  }


  .numerito1{
    height: 100% !important;
  }

  #numero11{
    height: 80% !important; 
  }
  /* Contenedor principal que se alinea con tu Grid */
  .menu-interactivo-numeros {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between !important;
    gap: 0px; /* Espacio entre flechas y números */
    width: 100%;
    height: 100%;
    grid-column: 26/31;
    grid-row: 5/15;
  }

  /* Estilos para limpiar los botones nativos y hacerlos interactivos */
  .btn-flecha {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-flecha img {
    width: 22%; /* Ajusta el tamaño de tus flechas aquí */
    height: auto;
  }

  /* 🚀 LA MAGIA: Clase que desactiva la flecha cuando topamos el límite */
  .desactivado {
    opacity: 0.3; /* Se vuelve semitransparente */
    pointer-events: none; /* Bloquea el clic */
    cursor: default;
  }

  /* Estilos para los bloques de números */
  .bloque-numeros {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2%; /* Espacio entre cada número */
    width: 100%;
    position: relative;
    top: 6%; /* Ajusta este valor para centrar verticalmente los números */
  }

  /* Clase para ocultar el bloque que no se está viendo */
  .oculto {
    display: none;
  }

  .btn-numero {
    display: block;
    width: 28%; /* Ajusta según lo ancho que quieras los números */
    transition: transform 0.2s ease;
  }

  .btn-numero img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Efecto sutil al pasar el mouse por encima de los números */
  .btn-numero:hover, .btn-flecha:hover:not(.desactivado) {
    transform: scale(1.25);
  }
</style>

<script>
  const inicializarMenuDerecho = () => {
    const contenedor = document.getElementById('barraderecha');
    if (!contenedor) return;

    let paginaInicial = parseInt(contenedor.dataset.paginaInicial, 10);
    // SALVAVIDAS: Si el número de página inicial falla o no está entre 1 y 4, forzar la 1
    if (isNaN(paginaInicial) || paginaInicial < 1 || paginaInicial > 4) {
      paginaInicial = 1;
    }

    const btnArriba = document.getElementById('btn-arriba');
    const btnAbajo = document.getElementById('btn-abajo');
    
    const grupo1 = document.getElementById('grupo-numeros-1');
    const grupo2 = document.getElementById('grupo-numeros-2');
    const grupo3 = document.getElementById('grupo-numeros-3');
    const grupo4 = document.getElementById('grupo-numeros-4');

    let paginaActualMenu = paginaInicial;

    const actualizarVistaMenu = () => {
      // Ocultar de forma segura únicamente los elementos que existan en el DOM
      if (grupo1) grupo1.classList.add('oculto');
      if (grupo2) grupo2.classList.add('oculto');
      if (grupo3) grupo3.classList.add('oculto');
      if (grupo4) grupo4.classList.add('oculto');

      if (btnArriba) btnArriba.classList.remove('desactivado');
      if (btnAbajo) btnAbajo.classList.remove('desactivado');

      // Mostrar grupo activo dependiendo de la página
      if (paginaActualMenu === 1 && grupo1) {
        grupo1.classList.remove('oculto');
        if (btnArriba) btnArriba.classList.add('desactivado');
      } else if (paginaActualMenu === 2 && grupo2) {
        grupo2.classList.remove('oculto');
      } else if (paginaActualMenu === 3 && grupo3) {
        grupo3.classList.remove('oculto');
      } else if (paginaActualMenu === 4 && grupo4) {
        grupo4.classList.remove('oculto');
        if (btnAbajo) btnAbajo.classList.add('desactivado');
      }
    };

    // Ejecutar renderizado inicial seguro
    actualizarVistaMenu();

    // Eventos de click utilizando funciones directas para no duplicar escuchadores con Astro View Transitions
    if (btnArriba) {
      btnArriba.onclick = () => {
        if (paginaActualMenu > 1) {
          paginaActualMenu--;
          actualizarVistaMenu();
        }
      };
    }

    if (btnAbajo) {
      btnAbajo.onclick = () => {
        if (paginaActualMenu < 4) {
          paginaActualMenu++;
          actualizarVistaMenu();
        }
      };
    }
  };

  // Eventos para asegurar que el script se cargue bien en Astro
  document.addEventListener('DOMContentLoaded', inicializarMenuDerecho);
  document.addEventListener('astro:page-load', inicializarMenuDerecho);
</script>